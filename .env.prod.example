# =========================================================
# Production env vars (Coolify -> Application -> Environment)
# Copy these into Coolify; do NOT commit a filled .env.prod
# =========================================================

# --- Django core ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-generate-a-long-random-string
DJANGO_DEBUG=False
# "*" = accept any host (OK behind Coolify reverse proxy). Or set explicit hosts.
DJANGO_ALLOWED_HOSTS=*
# Required when DEBUG=False and POST/PUT through proxy. Use the public HTTPS URLs.
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.example.sslip.io,https://app.example.sslip.io
DJANGO_CORS_ALLOWED_ORIGINS=https://app.example.sslip.io
DJANGO_LANGUAGE_CODE=fr-fr
DJANGO_TIME_ZONE=Europe/Paris

# --- Gunicorn ---
GUNICORN_WORKERS=3

# --- SMTP (OVH) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=ssl0.ovh.net
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=no-reply@example.com
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=no-reply@example.com

# --- Frontend URLs ---
# Used by Django to build links in emails (invitations).
FRONTEND_BASE_URL=https://app.example.sslip.io
# Baked into the Next.js build (NEXT_PUBLIC_*). Must be the PUBLIC backend URL.
NEXT_PUBLIC_API_BASE_URL=https://api.example.sslip.io
